# FREA — Freelancer Tool
# Copy to .env.local and fill in your values

# Required
COMPANY_NAME="Dein Firmenname"
EMAIL="deine@email.de"
IBAN="DE00 0000 0000 0000 0000 00"
BIC="XXXXXXXX"
TAX_NUMBER="000/000/00000"

# Optional
ADDRESS="Musterstraße 1"
POSTAL_CODE="12345"
CITY="Berlin"
COUNTRY="Deutschland"
PHONE="+49 30 12345678"
MOBILE=""
BANK_NAME="Musterbank"
UST_ID=""

# DB path (default: ./data/frea.db)
# FREA_DB_PATH=/absolute/path/to/frea.db

# Server port (default: 3114)
# PORT=3114
