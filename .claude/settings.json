{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | grep -q 'git push' && exit 0; exit 1",
            "if": "Bash(git push*)",
            "async": true,
            "asyncRewake": false
          }
        ]
      }
    ]
  }
}
