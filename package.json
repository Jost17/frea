{
  "name": "frea",
  "version": "0.1.0",
  "description": "FREA — German freelancer invoicing tool",
  "type": "module",
  "scripts": {
    "css:build": "bunx @tailwindcss/cli -i ./src/styles/input.css -o ./public/static/styles.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i ./src/styles/input.css -o ./public/static/styles.css --watch",
    "dev": "bun run css:build && (bun run css:watch & PID=$!; trap 'kill $PID' EXIT; bun run --watch src/index.ts)",
    "start": "bun run css:build && bun run src/index.ts",
    "db:setup": "bun run src/db/setup.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:zugferd": "bun run src/__tests__/validate-zugferd.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx @biomejs/biome lint .",
    "format": "bunx @biomejs/biome format --write .",
    "check": "bunx @biomejs/biome check --write .",
    "setup:hooks": "bash scripts/setup-hooks.sh"
  },
  "dependencies": {
    "hono": "^4.12.16",
    "htmx.org": "^2.0.10",
    "lucide": "^1.14.0",
    "nodemailer": "8.0.7",
    "puppeteer": "24.42.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/nodemailer": "^8.0.0",
    "bun-types": "latest",
    "tailwindcss": "^4.2.4"
  }
}
